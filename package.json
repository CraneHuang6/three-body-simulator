{
  "name": "three-body-simulator",
  "version": "0.1.0",
  "private": true,
  "description": "Three Body desktop simulator with cinematic story mode and interactive four-body controls.",
  "author": "Codex + crane",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "vite build",
    "test": "vitest run",
    "package": "npm run package:mac",
    "package:mac": "npm run build && node scripts/package-mac-free.mjs",
    "package:mac:zip": "npm run build && node scripts/package-mac-free.mjs",
    "package:win": "npm run package:win:x64",
    "package:win:x64": "npm run build && node scripts/package-win.mjs x64",
    "package:release": "bash scripts/package-release.sh"
  },
  "build": {
    "appId": "com.crane.threebodysimulator",
    "productName": "ThreeBodySimulator",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "mac": {
      "icon": "build/app-icon.icns",
      "artifactName": "三体模拟器-${version}-${arch}-mac.${ext}",
      "target": [
        "zip"
      ]
    },
    "win": {
      "icon": "build/app-icon.ico",
      "artifactName": "三体模拟器-${version}-${arch}.${ext}",
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "jsdom": "^24.1.1",
    "vite": "^5.4.10",
    "vitest": "^2.1.3",
    "wait-on": "^8.0.1"
  }
}
